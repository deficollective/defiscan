                    "Liquid staking protocol": "staking",
                    "Wrapped ETH": "canonical"
                  }
                }
              ]
            }
          ]
        },
        {
          "title": "Morpho Protocol",
          "content": [
            {
              "type": "text",
              "content": "The vault depends on the Morpho Blue singleton contract for all lending operations. Morpho Blue is immutable and permissionless."
            }
          ]
        }
      ]
    },
